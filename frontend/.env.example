# Frontend environment variables (Vite)
#
# Copy this file to .env.local for local development, or set as env vars in Vercel
# (Settings → Environment Variables) for production.
#
# .env.local is gitignored. NEVER commit real tokens.

# Optional: Things 3 (Cultured Code) auth-token.
# NOT required for the dashboard's "Send to Things" button to work (the `add`
# command works without it). Only useful if you later want to UPDATE existing
# Things tasks via URL Scheme.
#
# How to get it: in Things → Settings → General → "Enable Things URLs" →
# Manage → copy "Authorization Token". macOS only.
#
# Leave blank to omit. If set, the button includes &auth-token=... in the URL.
VITE_THINGS_AUTH_TOKEN=
