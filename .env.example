# API Configuration
ANTHROPIC_API_KEY=sk-...
XAI_API_KEY=xai-...   # Optional: enables X/Twitter cardiology highlights via Grok
GOOGLE_API_KEY=AIza...  # Gemini Flash for journal/Substack/Bluesky fetchers (paid tier recommended; free tier = 20 req/day)

# Optional NCBI E-utilities API key (free)
# Without: PubMed limits to 3 req/s and our 2nd parallel query frequently 429s.
# With: 10 req/s. Register at https://www.ncbi.nlm.nih.gov/account/settings/ (API Key Management).
NCBI_API_KEY=
NCBI_EMAIL=          # optional; NCBI recommends including for support contact
NCBI_TOOL=cardiology-agent

# Optional Webshare residential proxy for YouTube transcript fetching.
# Without: GitHub Actions IPs (datacenter) are blocked by YouTube → 0% transcripts.
# With: requests route through residential IPs → ~95% transcript success.
# Sign up at https://www.webshare.io/ — cheapest plan with residential IPs is ~$6/mo.
# After sign-up, find Username + Password in dashboard → Proxy → Settings.
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=

# Download service configuration
GOOGLE_SERVICE_ACCOUNT_JSON=./config/service-account.json
DOWNLOAD_TEMP_DIR=/tmp/downloads
PLAYWRIGHT_HEADLESS=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
